# ─────────────────────────────────────────────────────────────
# AI 自然语言事件创建（目玉功能）
# ─────────────────────────────────────────────────────────────
# 这两个变量都不填时，应用会自动使用「本地启发式 mock 解析器」，
# 无需任何外部服务即可运行和演示。
#
# 想接入真正的 Claude：复制本文件为 .env.local，填入你的 key。
#   cp .env.example .env.local
#
# 你的 Anthropic API Key（服务端使用，绝不暴露给浏览器）
ANTHROPIC_API_KEY=

# 使用的模型（默认 claude-opus-4-8）。
# 这是高频、低延迟的解析任务，若想控制成本可改用 claude-sonnet-4-6。
ANTHROPIC_MODEL=claude-opus-4-8

# ─────────────────────────────────────────────────────────────
# Supabase（账号 / 数据库 / 管理后台）
# ─────────────────────────────────────────────────────────────
# Project Settings → API 里能找到这三个值。
#
# 浏览器可见，可以放心暴露：
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
#
# 绝密：只能在服务端代码（API Route / Route Handler）里使用，
# 绝对不要加 NEXT_PUBLIC_ 前缀，绝对不要在客户端组件里引用它。
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────
# 管理员后台（/admin）
# ─────────────────────────────────────────────────────────────
# 能访问 /admin 的邮箱白名单，逗号分隔。必须是你用来登录本应用（Supabase Auth）的邮箱。
# 服务端使用，绝不暴露给浏览器。
ADMIN_EMAILS=
